generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int           @id @default(autoincrement())
  name               String
  email              String        @unique
  passwordHash       String
  role               Role          @default(JOBSEEKER)
  tokens             Int           @default(0)
  referralCode       String?       @unique
  referredById       Int?
  referralMilestone10NotifiedAt DateTime? @db.Timestamp(6)
  emailVerified      Boolean       @default(false)
  emailVerifiedAt    DateTime?     @db.Timestamp(6)
  emailVerifyToken   String?       @unique
  emailVerifyExpires DateTime?     @db.Timestamp(6)
  resetTokenHash     String?
  resetTokenExpires  DateTime?     @db.Timestamp(6)
  createdAt          DateTime      @default(now()) @db.Timestamp(6)
  updatedAt          DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  applications       Application[]
  company            Company?      @relation("CompanyOwner")
  jobs               Job[]         @relation("JobPostedBy")
  savedJobs          SavedJob[]
  notifications      Notification[]
  blogPosts          BlogPost[]
  referredBy         User?         @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals          User[]        @relation("UserReferrals")
  referralActivities ReferralActivity[]
}

model Company {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  industry    String?
  location    String?
  logoPath    String?
  verified    Boolean @default(false)
  website     String?
  regNo       String?
  proofNote   String?
  facebook    String?
  instagram   String?
  linkedin    String?
  x           String?
  youtube     String?
  ownerId     Int     @unique
  owner       User    @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_company_owner")
  jobs        Job[]
}

model Job {
  id                Int           @id @default(autoincrement())
  title             String
  description       String
  category          String?
  type              String?
  location          String?
  workMode          WorkMode?
  status            JobStatus     @default(OPEN)
  isFeatured        Boolean       @default(false)
  createdAt         DateTime      @default(now()) @db.Timestamp(6)
  updatedAt         DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  applicationFields Json?         @db.Json
  companyId         Int
  postedById        Int
  applications      Application[]
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_job_company")
  postedBy          User          @relation("JobPostedBy", fields: [postedById], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_job_postedby")
  savedByUsers      SavedJob[]
}

model Application {
  id            Int               @id @default(autoincrement())
  cvPath        String
  coverLetter   String?
  status        ApplicationStatus @default(APPLIED)
  createdAt     DateTime          @default(now()) @db.Timestamp(6)
  updatedAt     DateTime          @default(now()) @updatedAt @db.Timestamp(6)
  customAnswers Json?             @db.Json
  jobId         Int
  applicantId   Int
  applicant     User              @relation(fields: [applicantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_application_applicant")
  job           Job               @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_application_job")

  @@unique([jobId, applicantId], map: "uq_job_applicant")
}

model SavedJob {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @db.Timestamp(6)
  userId    Int
  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_savedjob_job")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_savedjob_user")

  @@unique([userId, jobId], map: "uq_user_job")
}

model AppSetting {
  key      String @id
  valueInt Int?
}

model LocationOption {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(6)
}

model TokenPlan {
  id        String   @id @default(cuid())
  tokens    Int
  price     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // 'WELCOME', 'COMPANY_CREATED', 'COMPANY_VERIFIED', 'NEW_APPLICATION', 'TOKENS_CREDITED', 'APPLICATION_SHORTLISTED', 'APPLICATION_REJECTED', 'COMPANY_AWAITING_VERIFICATION'
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json?    @db.Json // Store additional data like jobId, applicationId, etc
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([read])
}

model ReferralActivity {
  id          Int      @id @default(autoincrement())
  userId       Int
  type         String
  title        String
  description  String
  metadata     Json?    @db.Json
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt])
}

model BlogPost {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  published   Boolean   @default(false)
  publishedAt DateTime? @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  authorId    Int
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum Role {
  ADMIN
  EMPLOYER
  JOBSEEKER
}

enum JobStatus {
  OPEN
  CLOSED
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
}
