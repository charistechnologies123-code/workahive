generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")      // pooler URL (pgbouncer)
  directUrl = env("DIRECT_URL")        // direct URL (port 5432, no pgbouncer)
}

model User {
  id                 Int           @id @default(autoincrement())
  name               String
  email              String        @unique
  passwordHash       String
  role               Role          @default(JOBSEEKER)
  tokens             Int           @default(0)
  emailVerified      Boolean       @default(false)
  emailVerifiedAt    DateTime?     @db.Timestamp(6)
  emailVerifyToken   String?       @unique
  emailVerifyExpires DateTime?     @db.Timestamp(6)
  resetTokenHash     String?
  resetTokenExpires  DateTime?     @db.Timestamp(6)
  createdAt          DateTime      @default(now()) @db.Timestamp(6)
  updatedAt          DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  applications       Application[]
  company            Company?      @relation("CompanyOwner")
  jobs               Job[]         @relation("JobPostedBy")
  savedJobs          SavedJob[]
  otpCode            String?   // new field for OTP
  otpExpires         DateTime? // optional: expiration
}

model Company {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  industry    String?
  location    String?
  logoPath    String?
  verified    Boolean @default(false)
  website     String?
  regNo       String?
  proofNote   String?
  facebook    String?
  instagram   String?
  linkedin    String?
  x           String?
  youtube     String?
  ownerId     Int     @unique
  owner       User    @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_company_owner")
  jobs        Job[]
}

model Job {
  id                Int           @id @default(autoincrement())
  title             String
  description       String
  category          String?
  type              String?
  location          String?
  workMode          WorkMode?
  status            JobStatus     @default(OPEN)
  isFeatured        Boolean       @default(false)
  createdAt         DateTime      @default(now()) @db.Timestamp(6)
  updatedAt         DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  applicationFields Json?         @db.Json
  companyId         Int
  postedById        Int
  applications      Application[]
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_job_company")
  postedBy          User          @relation("JobPostedBy", fields: [postedById], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_job_postedby")
  savedByUsers      SavedJob[]
}

model Application {
  id            Int               @id @default(autoincrement())
  cvPath        String
  coverLetter   String?
  status        ApplicationStatus @default(APPLIED)
  createdAt     DateTime          @default(now()) @db.Timestamp(6)
  updatedAt     DateTime          @default(now()) @updatedAt @db.Timestamp(6)
  customAnswers Json?             @db.Json
  jobId         Int
  applicantId   Int
  applicant     User              @relation(fields: [applicantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_application_applicant")
  job           Job               @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_application_job")

  @@unique([jobId, applicantId], map: "uq_job_applicant")
}

model SavedJob {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @db.Timestamp(6)
  userId    Int
  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_savedjob_job")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_savedjob_user")

  @@unique([userId, jobId], map: "uq_user_job")
}

model AppSetting {
  key      String @id
  valueInt Int?
}

model LocationOption {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(6)
}

enum Role {
  ADMIN
  EMPLOYER
  JOBSEEKER
}

enum JobStatus {
  OPEN
  CLOSED
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
}
